{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "@playwright/test"]
  },
  "include": ["*.ts", "config/config.ts", "framework/auth/authenticator.ts", "framework/browser/browserManager.ts", "framework/pages/workbenchPage.ts", "framework/services/formHandler.ts", "framework/services/workbenchService.ts", "framework/services/projectSelector.ts", "framework/pages/dashboardKebabMenu.ts", "scripts/debug.ts", "scripts/debug_login.ts"],
  "exclude": ["node_modules"]
}
